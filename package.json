{
  "name": "requester",
  "version": "1.0.0",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev:stop": "node scripts/dev-stop.js",
    "predev": "npm run dev:stop",
    "dev:ui": "vite",
    "dev:electron": "npm run build:electron && wait-on tcp:5173 && node scripts/run-electron.js . --dev-server-url=http://127.0.0.1:5173",
    "dev": "concurrently -k \"npm:dev:ui\" \"npm:dev:electron\"",
    "build:ui": "vite build",
    "build:electron": "node -e \"require('fs').rmSync('dist-electron', { recursive: true, force: true })\" && tsc -p tsconfig.node.json",
    "build": "npm run build:ui && npm run build:electron",
    "start": "node scripts/run-electron.js .",
    "pack": "npm run build && electron-builder",
    "test": "vitest",
    "lint": "node scripts/run-lint.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "build": {
    "appId": "com.local.api-client",
    "productName": "Local API Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ]
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
